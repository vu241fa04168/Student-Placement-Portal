# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/placement_system?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your-super-secure-secret-key-change-this

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Brevo Email Configuration
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-email@example.com
BREVO_SENDER_NAME=Placement Portal

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-backend-domain.com

# OTP Configuration
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5
